@dc:title "Subsystem list"
@dc:description "Subsystems"
description <http://dw-oml-3.github.io/ss#> as ss {
    uses <http://purl.org/dc/elements/1.1/> as dc
    //uses <http://www.w3.org/2001/XMLSchema#> as xsd
    uses <http://dw-oml-3.github.io/foundation/base/base#> as base
    //uses <http://dw-oml-3.github.io/foundation/project/project#> as project
    uses <http://dw-oml-3.github.io/foundation/system/system#> as system

    // TODO: extend supplies relation from WorkPackage

    instance SS_POWER : system:Subsystem [
        base:hasCanonicalName "Power Subsystem"
        system:hasSubsystemId "POWER"
    ]

    instance SS_PROP : system:Subsystem [
        base:hasCanonicalName "Propulsion Subsystem"
        system:hasSubsystemId "PROP"
    ]
}